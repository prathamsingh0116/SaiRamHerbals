<% layout("layouts/auth") %>

<section class="auth-page">

    <!--==================================
                LEFT SIDE
    ===================================-->

    <div class="auth-left">

        <div class="auth-overlay"></div>

        <div class="auth-content">

            <div class="brand-chip">

                <i class='bx bx-reset'></i>

                Secure Password Reset

            </div>

            <h1>

                Create a

                <span>

                    New Password

                </span>

            </h1>

            <p>

                Your identity has been verified successfully.
                Create a strong password to keep your
                SaiRam Herbals account safe and secure.

            </p>

            <div class="auth-features">

                <div class="feature-item">

                    <i class='bx bx-check-circle'></i>

                    <span>

                        Strong Password Protection

                    </span>

                </div>

                <div class="feature-item">

                    <i class='bx bx-check-circle'></i>

                    <span>

                        Secure Encrypted Storage

                    </span>

                </div>

                <div class="feature-item">

                    <i class='bx bx-check-circle'></i>

                    <span>

                        Instant Password Update

                    </span>

                </div>

                <div class="feature-item">

                    <i class='bx bx-check-circle'></i>

                    <span>

                        Trusted By 50,000+ Users

                    </span>

                </div>

            </div>

            <div class="auth-stats">

                <div class="stat-card">

                    <div class="stat-icon">

                        <i class='bx bx-lock-alt'></i>

                    </div>

                    <h3>

                        256-bit

                    </h3>

                    <span>

                        SSL Security

                    </span>

                </div>

                <div class="stat-card">

                    <div class="stat-icon">

                        <i class='bx bx-shield-quarter'></i>

                    </div>

                    <h3>

                        100%

                    </h3>

                    <span>

                        Secure Password

                    </span>

                </div>

                <div class="stat-card">

                    <div class="stat-icon">

                        <i class='bx bx-check-shield'></i>

                    </div>

                    <h3>

                        Safe

                    </h3>

                    <span>

                        Recovery Process

                    </span>

                </div>

                <div class="stat-card">

                    <div class="stat-icon">

                        <i class='bx bx-user-check'></i>

                    </div>

                    <h3>

                        Trusted

                    </h3>

                    <span>

                        Herbal Brand

                    </span>

                </div>

            </div>

            <div class="hero-image">

                <img

                src="https://png.pngtree.com/png-clipart/20250108/original/pngtree-home-decor-herbal-oil-display-in-glass-bottles-png-image_19649631.png"

                alt="Reset Password">

            </div>

        </div>

    </div>



    <!--==================================
                RIGHT SIDE
    ===================================-->

    <div class="auth-right">

        <div class="login-card">

            <div class="back-home">

                <a href="/login">

                    <i class='bx bx-arrow-back'></i>

                    Back To Login

                </a>

            </div>

            <a href="/" class="brand-logo">

                <i class='bx bxs-leaf'></i>

                SaiRam Herbals

            </a>

            <h2>

                Reset Password 🔑

            </h2>

            <p>

                Choose a strong password that you haven't
                used before.

            </p>

            <form action="/reset-password/<%= user._id %>" method="POST">

                <!-- PASSWORD -->

                <div class="input-group">

                    <label>

                        New Password

                    </label>

                    <div class="input-box">

                        <i class='bx bx-lock-alt'></i>

                        <input

                        type="password"

                        id="password"

                        name="password"

                        placeholder="Enter New Password"

                        autocomplete="new-password"

                        required>

                        <span

                        class="toggle-password"

                        data-target="password">

                            <i class='bx bx-show'></i>

                        </span>

                    </div>

                    <small class="caps-lock-warning">

                        ⚠ Caps Lock is ON

                    </small>

                </div>



                <!-- PASSWORD STRENGTH -->

                <div class="password-strength">

                    <div class="strength-bar">

                        <div class="strength-fill"></div>

                    </div>

                    <span class="strength-text">

                        Password Strength

                    </span>

                </div>



                <!-- RULES -->

                <div class="password-rules">

                    <div class="rule length">

                        <i class='bx bx-x-circle'></i>

                        Minimum 8 Characters

                    </div>

                    <div class="rule uppercase">

                        <i class='bx bx-x-circle'></i>

                        One Uppercase Letter

                    </div>

                    <div class="rule number">

                        <i class='bx bx-x-circle'></i>

                        One Number

                    </div>

                    <div class="rule special">

                        <i class='bx bx-x-circle'></i>

                        One Special Character

                    </div>

                </div>



                <!-- CONFIRM PASSWORD -->

                <div class="input-group">

                    <label>

                        Confirm Password

                    </label>

                    <div class="input-box">

                        <i class='bx bx-lock'></i>

                        <input

                        type="password"

                        id="confirmPassword"

                        name="confirmPassword"

                        placeholder="Confirm Password"

                        autocomplete="new-password"

                        required>

                        <span

                        class="toggle-password"

                        data-target="confirmPassword">

                            <i class='bx bx-show'></i>

                        </span>

                    </div>

                    <small class="password-match"></small>

                </div>



                <button

                type="submit"

                class="login-btn"

                id="updatePasswordBtn">

                    <i class='bx bx-check-shield'></i>

                    <span>

                        Update Password

                    </span>

                </button>

            </form>



            <div class="security-box">

                <div class="security-item">

                    <i class='bx bx-info-circle'></i>

                    <div>

                        <h4>

                            Password Tips

                        </h4>

                        <p>

                            Avoid using your name, phone number,
                            or previous passwords. Choose a unique
                            and strong password for maximum security.

                        </p>

                    </div>

                </div>

            </div>



            <div class="trust-footer">

                <div>

                    <i class='bx bx-lock-alt'></i>

                    SSL Protected

                </div>

                <div>

                    <i class='bx bx-check-shield'></i>

                    Encrypted Data

                </div>

                <div>

                    <i class='bx bx-certification'></i>

                    Trusted Platform

                </div>

            </div>

        </div>

    </div>



    <div class="shape shape-1"></div>

    <div class="shape shape-2"></div>

    <div class="shape shape-3"></div>

    <div class="shape shape-4"></div>

</section>



