<% layout("layouts/auth") %>

<section class="auth-page">

    <!--==========================
            LEFT PANEL
    ===========================-->

    <div class="auth-left">

        <div class="auth-overlay"></div>

        <div class="auth-content">

            <div class="brand-chip">

                <i class='bx bxs-shield'></i>

                Secure Account Recovery

            </div>

            <h1>

                Forgot Your Password?

                <span>

                    Don't Worry, We've Got You.

                </span>

            </h1>

            <p>

                Verify your registered email address and mobile
                number to securely recover access to your
                SaiRam Herbals account.

            </p>

            <div class="auth-features">

                <div class="feature-item">

                    <i class='bx bx-check-circle'></i>

                    <span>

                        Secure Identity Verification

                    </span>

                </div>

                <div class="feature-item">

                    <i class='bx bx-check-circle'></i>

                    <span>

                        Fast Password Recovery

                    </span>

                </div>

                <div class="feature-item">

                    <i class='bx bx-check-circle'></i>

                    <span>

                        Your Data Remains Protected

                    </span>

                </div>

                <div class="feature-item">

                    <i class='bx bx-check-circle'></i>

                    <span>

                        Trusted By Thousands Of Customers

                    </span>

                </div>

            </div>


            <div class="hero-image">

                <img

                src="https://png.pngtree.com/png-clipart/20250108/original/pngtree-home-decor-herbal-oil-display-in-glass-bottles-png-image_19649631.png"

                alt="Forgot Password">

            </div>

        </div>

    </div>

    <!--==========================
            RIGHT PANEL
    ===========================-->

    <div class="auth-right">

        <div class="login-card">

            <div class="back-home">

                <a href="/login">

                    <i class='bx bx-arrow-back'></i>

                    Back To Login

                </a>

            </div>

            <a href="/" class="brand-logo">

                <i class='bx bxs-leaf'></i>

                SaiRam Herbals

            </a>

            <h2>

                Forgot Password 🔑

            </h2>

            <p>

                Verify your identity using your registered
                email address and mobile number.

            </p>

            <form

            action="/forgot-password"

            method="POST"

            id="forgotPasswordForm">

                <!-- EMAIL -->

                <div class="input-group">

                    <label>

                        Registered Email Address

                    </label>

                    <div class="input-box">

                        <i class='bx bx-envelope'></i>

                        <input

                        type="email"

                        id="email"

                        name="email"

                        placeholder="Enter Registered Email"

                        autocomplete="email"

                        required>

                    </div>

                    <small class="error-text"></small>

                </div>

                <!-- MOBILE -->

                <div class="input-group">

                    <label>

                        Registered Mobile Number

                    </label>

                    <div class="input-box">

                        <i class='bx bx-phone'></i>

                        <input

                        type="tel"

                        id="phone"

                        name="phone"

                        maxlength="10"

                        placeholder="Enter Registered Mobile Number"

                        autocomplete="tel"

                        required>

                    </div>

                    <small class="error-text"></small>

                </div>

                <div class="security-box">

                    <div class="security-item">

                        <i class='bx bx-info-circle'></i>

                        <div>

                            <h4>

                                Identity Verification

                            </h4>

                            <p>

                                Only users with matching registered
                                email address and mobile number
                                can continue to reset password.

                            </p>

                        </div>

                    </div>

                </div>

                <button

                class="login-btn"

                id="verifyBtn"

                type="submit">

                    <i class='bx bx-check-shield'></i>

                    <span>

                        Verify Identity

                    </span>

                </button>

            </form>

            <div class="divider">

                <span>

                    NEED HELP?

                </span>

            </div>

            <div class="register-box">

                <span>

                    Remember your password?

                </span>

                <a href="/login">

                    Login Here

                </a>

            </div>

            <div class="trust-footer">

                <div>

                    <i class='bx bx-lock-alt'></i>

                    SSL Protected

                </div>

                <div>

                    <i class='bx bx-check-shield'></i>

                    Secure Verification

                </div>

                <div>

                    <i class='bx bx-certification'></i>

                    Trusted Platform

                </div>

            </div>

        </div>

    </div>

    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>
    <div class="shape shape-4"></div>

</section>