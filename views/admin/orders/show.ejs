<% layout("layouts/admin") %>

<div class="order-page">

    <!-- Header -->

    <div class="order-header">

        <div>

            <a href="/admin/orders" class="back-btn">

                <i class='bx bx-arrow-back'></i>

                Back to Orders

            </a>

            <h1>

                Order #<%= order._id.toString().slice(-8).toUpperCase() %>

            </h1>

            <p>

                Placed on

                <%= order.createdAt.toDateString() %>

            </p>

        </div>

        <div>

            <span class="status-badge <%= order.orderStatus.toLowerCase() %>">

                <%= order.orderStatus %>

            </span>

        </div>

    </div>



    <!-- Top Grid -->

    <div class="top-grid">

        <!-- LEFT -->

        <div class="left-side">

            <!-- Customer -->

            <div class="card">

                <div class="card-title">

                    <i class='bx bx-user'></i>

                    Customer

                </div>

                <div class="customer-info">

                    <h3>

                        <%= order.user?.name || "Customer" %>

                    </h3>

                    <p>

                        <%= order.user?.email || "-" %>

                    </p>

                </div>

            </div>



            <!-- Address -->

            <div class="card">

                <div class="card-title">

                    <i class='bx bx-map'></i>

                    Delivery Address

                </div>

                <div class="address-info">

                    <strong>

                        <%= order.address.fullName %>

                    </strong>

                    <p>

                        <%= order.address.address %>

                    </p>

                    <p>

                        <%= order.address.city %>,

                        <%= order.address.state %>

                    </p>

                    <p>

                        PIN -

                        <%= order.address.pincode %>

                    </p>

                    <p>

                        📞

                        <%= order.address.phone %>

                    </p>

                </div>

            </div>

        </div>



        <!-- RIGHT -->

        <div class="right-side">

            <!-- Payment -->

            <div class="card">

                <div class="card-title">

                    <i class='bx bx-wallet'></i>

                    Payment

                </div>

                <div class="info-list">

                    <div>

                        <span>Method</span>

                        <strong>

                            <%= order.paymentMethod %>

                        </strong>

                    </div>

                    <div>

                        <span>Status</span>

                        <strong>

                            <%= order.paymentStatus %>

                        </strong>

                    </div>

                </div>

            </div>



            <!-- Summary -->

            <div class="card">

                <div class="card-title">

                    <i class='bx bx-receipt'></i>

                    Order Summary

                </div>

                <div class="summary">

                    <div>

                        <span>Subtotal</span>

                        <strong>

                            ₹<%= order.subtotal.toFixed(2) %>

                        </strong>

                    </div>

                    <div>

                        <span>Coupon</span>

                        <strong>

                            -₹<%= order.couponDiscount.toFixed(2) %>

                        </strong>

                    </div>

                    <div>

                        <span>Shipping</span>

                        <strong>

                            <%= order.shippingCharge==0?"FREE":"₹"+order.shippingCharge %>

                        </strong>

                    </div>

                    <div>

                        <span>Savings</span>

                        <strong class="green">

                            ₹<%= order.totalSavings.toFixed(2) %>

                        </strong>

                    </div>

                    <hr>

                    <div class="grand-total">

                        <span>

                            Grand Total

                        </span>

                        <strong>

                            ₹<%= order.grandTotal.toFixed(2) %>

                        </strong>

                    </div>

                </div>

            </div>

        </div>

    </div>



    <!-- Products -->

    <div class="card">

        <div class="card-title">

            <i class='bx bx-package'></i>

            Ordered Products

        </div>

        <% order.items.forEach(item=>{ %>

        <div class="product-item">

            <div class="product-left">

                <img

                src="<%= item.image %>"

                class="product-image"

                alt="">

                <div>

                    <h3>

                        <%= item.name %>

                    </h3>

                    <p>

                        Quantity :

                        <%= item.quantity %>

                    </p>

                </div>

            </div>

            <div class="product-right">

                <div>

                    ₹<%= item.price.toFixed(2) %>

                </div>

                <strong>

                    ₹<%= (item.price*item.quantity).toFixed(2) %>

                </strong>

            </div>

        </div>

        <% }) %>

    </div>



    <!-- Status Update -->

    <div class="card">

        <div class="card-title">

            <i class='bx bx-refresh'></i>

            Update Order Status

        </div>

        <form
action="/admin/orders/<%= order._id %>/status?_method=PUT"
method="POST">

<div class="status-update">

<select
name="orderStatus">

<option
value="Pending"
<%= order.orderStatus==="Pending" ? "selected":"" %>>
Pending
</option>

<option
value="Confirmed"
<%= order.orderStatus==="Confirmed" ? "selected":"" %>>
Confirmed
</option>

<option
value="Packed"
<%= order.orderStatus==="Packed" ? "selected":"" %>>
Packed
</option>

<option
value="Shipped"
<%= order.orderStatus==="Shipped" ? "selected":"" %>>
Shipped
</option>

<option
value="Delivered"
<%= order.orderStatus==="Delivered" ? "selected":"" %>>
Delivered
</option>

<option
value="Cancelled"
<%= order.orderStatus==="Cancelled" ? "selected":"" %>>
Cancelled
</option>

</select>

<button

type="submit"

onclick="return confirmUpdate()">

Update Status

</button>

</div>

</form>

    </div>

</div>

<script>

function confirmUpdate(){

return confirm(

"Are you sure you want to update this order status?"

);

}

</script>