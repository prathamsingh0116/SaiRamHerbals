<% layout("layouts/main") %>

<div class="success-container">

    <div class="success-card">

        <div class="success-icon">

            <i class='bx bx-check'></i>

        </div>

        <h1>

            Order Placed Successfully!

        </h1>

        <p>

            Thank you for shopping with SaiRam Herbals.

        </p>

        <div class="order-details">

            <div>

                <span>Order ID</span>

                <strong>#<%= order._id.toString().slice(-8).toUpperCase() %></strong>

            </div>

            <div>

                <span>Payment</span>

                <strong><%= order.paymentMethod %></strong>

            </div>

            <div>

                <span>Status</span>

                <strong class="pending">

                    <%= order.orderStatus %>

                </strong>

            </div>

            <div>

                <span>Grand Total</span>

                <strong>

                    ₹<%= order.grandTotal.toFixed(2) %>

                </strong>

            </div>

        </div>

        <div class="delivery-box">

            <i class='bx bx-package'></i>

            Estimated Delivery

            <strong>

                3-5 Business Days

            </strong>

        </div>

        <div class="success-buttons">

            <a

            href="/orders"

            class="primary-btn">

                My Orders

            </a>

            <a

            href="/products"

            class="secondary-btn">

                Continue Shopping

            </a>

        </div>

    </div>

</div>