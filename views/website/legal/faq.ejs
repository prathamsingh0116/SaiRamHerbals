<% layout("layouts/main") %>

<link rel="stylesheet" href="/css/website/legal.css">

<section class="legal-hero">

    <div class="container">

        <div class="legal-breadcrumb">

            <a href="/">Home</a>

            <span>/</span>

            <span>Frequently Asked Questions</span>

        </div>

        <h1>

            Frequently Asked Questions

        </h1>

        <p>

            Find answers to the most common questions about orders,
            delivery, payments, returns, herbal products and more.

        </p>

        <div class="legal-search">

            <input
                type="text"
                id="faqSearch"
                placeholder="Search your question...">

            <i class='bx bx-search'></i>

        </div>

    </div>

</section>

<section class="faq-section">

<div class="container">

<div class="faq-wrapper">

<!-- ========================= -->

<div class="faq-item">

<div class="faq-question">

<h3>

How long does delivery take?

</h3>

<i class='bx bx-plus'></i>

</div>

<div class="faq-answer">

<p>

Orders are generally delivered within
3–7 business days depending upon
your location.

</p>

</div>

</div>

<!-- ========================= -->

<div class="faq-item">

<div class="faq-question">

<h3>

How can I track my order?

</h3>

<i class='bx bx-plus'></i>

</div>

<div class="faq-answer">

<p>

Once your order is shipped,
you will receive tracking details
via Email and SMS.

</p>

</div>

</div>

<!-- ========================= -->

<div class="faq-item">

<div class="faq-question">

<h3>

Can I cancel my order?

</h3>

<i class='bx bx-plus'></i>

</div>

<div class="faq-answer">

<p>

Yes.

You can cancel your order before
it has been shipped.

</p>

</div>

</div>

<!-- ========================= -->

<div class="faq-item">

<div class="faq-question">

<h3>

What payment methods do you accept?

</h3>

<i class='bx bx-plus'></i>

</div>

<div class="faq-answer">

<p>

We accept

Debit Card

Credit Card

UPI

Net Banking

Wallets

Cash on Delivery (selected locations).

</p>

</div>

</div>

<!-- ========================= -->

<div class="faq-item">

<div class="faq-question">

<h3>

Can I return herbal products?

</h3>

<i class='bx bx-plus'></i>

</div>

<div class="faq-answer">

<p>

Returns are accepted only
for damaged, incorrect or
expired products.

</p>

</div>

</div>

<!-- ========================= -->

<div class="faq-item">

<div class="faq-question">

<h3>

Are your products 100% Natural?

</h3>

<i class='bx bx-plus'></i>

</div>

<div class="faq-answer">

<p>

Yes.

Most products are prepared
using natural herbal ingredients.

Please read each product label
before use.

</p>

</div>

</div>

<!-- ========================= -->

<div class="faq-item">

<div class="faq-question">

<h3>

Do you offer Cash on Delivery?

</h3>

<i class='bx bx-plus'></i>

</div>

<div class="faq-answer">

<p>

Yes.

Cash on Delivery is available
on selected pincodes.

</p>

</div>

</div>

<!-- ========================= -->

<div class="faq-item">

<div class="faq-question">

<h3>

Can I modify my shipping address?

</h3>

<i class='bx bx-plus'></i>

</div>

<div class="faq-answer">

<p>

Address can be changed
before shipment.

Contact customer support immediately.

</p>

</div>

</div>

<!-- ========================= -->

<div class="faq-item">

<div class="faq-question">

<h3>

How do I contact support?

</h3>

<i class='bx bx-plus'></i>

</div>

<div class="faq-answer">

<p>

Email :

support@sairamherbals.com

<br><br>

Phone :

+91 XXXXX XXXXX

</p>

</div>

</div>

</div>

</div>

</section>

<section class="legal-contact">

<div class="container">

<div class="legal-contact-card">

<i class='bx bx-support'></i>

<h2>

Still have questions?

</h2>

<p>

Our support team is always ready
to help you.

</p>

<a href="/contact" class="contact-btn">

Contact Us

</a>

</div>

</div>

</section>

<script src="/js/legal.js"></script>