<section class="featured-products">

    <div class="container">

        <%- include("../../../partials/components/sectionHeading",{
            badge:"Premium Collection",
            title:"Our Best Selling Products",
            description:"Discover our most loved Ayurvedic products, crafted with natural ingredients for everyday wellness."
        }) %>

        <div class="featured-grid">

            <% featuredProducts.forEach(product => { %>

            <div class="featured-card">

                <% if(product.discount > 0){ %>
                <span class="discount-badge">
                    -<%= product.discount %>%
                </span>
                <% } %>

                <button class="wishlist-btn">
                    <i class='bx bx-heart'></i>
                </button>

                <a href="/products/<%= product.slug %>" class="featured-image">

                    <img
                        src="<%= product.images[0]?.url %>"
                        alt="<%= product.name %>">

                </a>

                <div class="featured-content">

                    <span class="product-chip">
                        🌿 Herbal Product
                    </span>

                    <h3>

                        <a href="/products/<%= product.slug %>">

                            <%= product.name %>

                        </a>

                    </h3>

                    <div class="featured-rating">

                        <div class="stars">

                            ★★★★★

                        </div>

                        <span>

                            4.9

                        </span>

                    </div>

                    <div class="featured-price">

                        <% if(product.discount>0){ %>

                        <span class="old-price">

                            ₹<%= product.price %>

                        </span>

                        <% } %>

                        <span class="new-price">

                            ₹<%= product.finalPrice || product.price %>

                        </span>

                    </div>

                    <a
                        href="/products/<%= product.slug %>"
                        class="view-product-btn">

                        View Details

                        <i class='bx bx-right-arrow-alt'></i>

                    </a>

                </div>

            </div>

            <% }) %>

        </div>

    </div>

</section>