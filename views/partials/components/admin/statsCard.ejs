<section class="admin-dashboard-stats-grid">

    <div class="admin-dashboard-stat-card">

        <div class="admin-dashboard-stat-left">

            <span class="admin-dashboard-stat-label">

                Total Products

            </span>

            <h2>

                <%= totalProducts %>

            </h2>

            <small>

                Products Available

            </small>

        </div>

        <div class="admin-dashboard-stat-icon">

            <i class='bx bx-package'></i>

        </div>

    </div>

    <div class="admin-dashboard-stat-card">

        <div class="admin-dashboard-stat-left">

